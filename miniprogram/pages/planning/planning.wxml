<view class="container">
  <view class="planning-content">
    <view class="status-icon">
      <text wx:if="{{status === 'QUEUED' || status === 'PROCESSING'}}">⏳</text>
      <text wx:elif="{{status === 'COMPLETED'}}">🎉</text>
      <text wx:else>⚠️</text>
    </view>

    <view class="status-text">
      <text class="status-title">{{statusTitle}}</text>
      <text class="status-desc">{{message}}</text>
    </view>

    <view class="progress-section" wx:if="{{status === 'QUEUED' || status === 'PROCESSING'}}">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
      <text class="progress-text">{{progress}}%</text>
    </view>

    <view class="steps-section" wx:if="{{status === 'QUEUED' || status === 'PROCESSING'}}">
      <view class="step-item {{currentStep >= 1 ? 'completed' : ''}}">
        <view class="step-circle"><text>1</text></view>
        <text class="step-text">分析需求</text>
      </view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 2 ? 'completed' : ''}}">
        <view class="step-circle"><text>2</text></view>
        <text class="step-text">检索景点</text>
      </view>
      <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 3 ? 'completed' : ''}}">
        <view class="step-circle"><text>3</text></view>
        <text class="step-text">规划路线</text>
      </view>
      <view class="step-line {{currentStep >= 4 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 4 ? 'completed' : ''}}">
        <view class="step-circle"><text>4</text></view>
        <text class="step-text">生成结果</text>
      </view>
    </view>

    <view class="result-preview card" wx:if="{{status === 'COMPLETED' && itinerary}}">
      <text class="preview-title">{{itinerary.title}}</text>
      <view class="preview-meta">
        <text class="preview-tag">{{itinerary.destination}}</text>
        <text class="preview-tag">{{dayCount}}天</text>
        <text class="preview-tag">{{itinerary.travelerCount}}人</text>
      </view>
      <text class="preview-summary" wx:if="{{summaryPreview}}">{{summaryPreview}}</text>
    </view>

    <view class="completed-section" wx:if="{{status === 'COMPLETED'}}">
      <button class="view-btn btn-primary" bindtap="viewItinerary">查看行程</button>
    </view>

    <view class="failed-section" wx:if="{{status === 'FAILED'}}">
      <button class="retry-btn" bindtap="retryPlan">重新提交</button>
      <button class="back-btn" bindtap="goBack">返回修改</button>
    </view>
  </view>
</view>
