<view class="container">
  <view class="login-content">
    <view class="logo-section">
      <view class="logo-icon"><text>🧳</text></view>
      <text class="logo-title">智能伴旅</text>
      <text class="logo-subtitle">最小闭环版本：登录、填写需求、查看行程。</text>
    </view>

    <view class="features-section">
      <view class="feature-item">
        <view class="feature-icon"><text>🤖</text></view>
        <view class="feature-text">
          <text class="feature-title">AI 生成行程</text>
          <text class="feature-desc">根据目的地、日期和人数生成基础方案。</text>
        </view>
      </view>
      <view class="feature-item">
        <view class="feature-icon"><text>📍</text></view>
        <view class="feature-text">
          <text class="feature-title">行程详情展示</text>
          <text class="feature-desc">按天查看景点、时间和备注。</text>
        </view>
      </view>
      <view class="feature-item">
        <view class="feature-icon"><text>📋</text></view>
        <view class="feature-text">
          <text class="feature-title">保存与管理</text>
          <text class="feature-desc">保存到“我的行程”，进行基础查看。</text>
        </view>
      </view>
    </view>

    <view class="login-section">
      <button class="login-btn" bindtap="mockLogin">演示登录</button>
      <text class="login-tips">当前版本使用本地演示登录，不接真实微信授权。</text>
    </view>

    <view class="guest-section">
      <text class="guest-text" bindtap="guestLogin">先以游客身份体验</text>
    </view>
  </view>
</view>
