<view class="container">
  <view class="form-header">
    <text class="header-title">填写行程需求</text>
    <text class="header-subtitle">这一步只负责收集最小输入：目的地、日期、人数。</text>
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">📍</text>
      <text class="label-text">目的地</text>
    </view>
    <input class="form-input" placeholder="例如：北京、上海、杭州" value="{{formData.destination}}" bindinput="onDestinationInput" />
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">📅</text>
      <text class="label-text">出行日期</text>
    </view>
    <view class="date-picker-row">
      <picker mode="date" value="{{formData.startDate}}" bindchange="onStartDateChange">
        <view class="date-picker"><text class="date-text">{{formData.startDate || '开始日期'}}</text></view>
      </picker>
      <text class="date-separator">至</text>
      <picker mode="date" value="{{formData.endDate}}" bindchange="onEndDateChange">
        <view class="date-picker"><text class="date-text">{{formData.endDate || '结束日期'}}</text></view>
      </picker>
    </view>
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">👥</text>
      <text class="label-text">出行人数</text>
    </view>
    <view class="counter-row">
      <view class="counter-btn" bindtap="decreaseCount"><text>-</text></view>
      <text class="count-text">{{formData.travelerCount}}</text>
      <view class="counter-btn" bindtap="increaseCount"><text>+</text></view>
    </view>
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">💰</text>
      <text class="label-text">预算范围（可选）</text>
    </view>
    <input class="form-input" type="digit" placeholder="请输入预算金额" value="{{formData.budget}}" bindinput="onBudgetInput" />
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">🎯</text>
      <text class="label-text">出行节奏</text>
    </view>
    <view class="options-row">
      <view class="option-item {{formData.preferences.pace === 'relaxed' ? 'active' : ''}}" bindtap="selectPace" data-pace="relaxed"><text>轻松</text></view>
      <view class="option-item {{formData.preferences.pace === 'moderate' ? 'active' : ''}}" bindtap="selectPace" data-pace="moderate"><text>适中</text></view>
      <view class="option-item {{formData.preferences.pace === 'intensive' ? 'active' : ''}}" bindtap="selectPace" data-pace="intensive"><text>紧凑</text></view>
    </view>
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">⭐</text>
      <text class="label-text">兴趣偏好</text>
    </view>
    <view class="interests-grid">
      <view class="interest-item {{interestMap.historical ? 'active' : ''}}" bindtap="toggleInterest" data-interest="historical"><text>历史文化</text></view>
      <view class="interest-item {{interestMap.natural ? 'active' : ''}}" bindtap="toggleInterest" data-interest="natural"><text>自然风光</text></view>
      <view class="interest-item {{interestMap.cultural ? 'active' : ''}}" bindtap="toggleInterest" data-interest="cultural"><text>民俗体验</text></view>
      <view class="interest-item {{interestMap.shopping ? 'active' : ''}}" bindtap="toggleInterest" data-interest="shopping"><text>购物</text></view>
      <view class="interest-item {{interestMap.food ? 'active' : ''}}" bindtap="toggleInterest" data-interest="food"><text>美食</text></view>
    </view>
  </view>

  <view class="form-section card">
    <view class="section-label">
      <text class="label-icon">⚙️</text>
      <text class="label-text">其他选项</text>
    </view>
    <view class="switch-row">
      <text class="switch-label">避开人流高峰</text>
      <switch checked="{{formData.preferences.avoidCrowds}}" bindchange="onAvoidCrowdsChange" />
    </view>
    <view class="switch-row">
      <text class="switch-label">包含餐饮推荐</text>
      <switch checked="{{formData.preferences.includeMeals}}" bindchange="onIncludeMealsChange" />
    </view>
  </view>

  <view class="submit-section">
    <button class="submit-btn btn-primary" bindtap="submitPlan" disabled="{{!canSubmit}}">开始规划</button>
  </view>
</view>
