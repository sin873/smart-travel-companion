<view class="container">
  <view wx:if="{{itinerary}}">
    <view class="itinerary-header">
      <view class="header-info">
        <text class="itinerary-title">{{itinerary.title}}</text>
        <view class="itinerary-meta">
          <text class="meta-item">🗓️ {{dateRange}}</text>
          <text class="meta-item">👥 {{itinerary.travelerCount}}人</text>
        </view>
      </view>
      <view class="header-actions">
        <button class="action-btn" bindtap="saveItinerary" wx:if="{{from === 'planning'}}">保存</button>
        <button class="action-btn" bindtap="shareItinerary">分享</button>
      </view>
    </view>

    <view class="days-container">
      <view class="day-card" wx:for="{{itinerary.days}}" wx:key="dayId" wx:for-item="day" wx:for-index="dayIndex">
        <view class="day-header" bindtap="toggleDay" data-index="{{dayIndex}}">
          <view class="day-info">
            <text class="day-number">Day {{day.dayNumber}}</text>
            <text class="day-date">{{day.displayDate}}</text>
            <text class="day-theme" wx:if="{{day.title}}">{{day.title}}</text>
          </view>
          <text class="toggle-icon {{day.expanded ? 'expanded' : ''}}">▼</text>
        </view>

        <view class="day-content" wx:if="{{day.expanded}}">
          <view class="timeline">
            <view class="timeline-item" wx:for="{{day.attractions}}" wx:key="itemId" wx:for-item="attr" wx:for-index="attrIndex">
              <view class="timeline-dot"></view>
              <view class="timeline-line" wx:if="{{attrIndex < day.attractions.length - 1}}"></view>
              <view class="timeline-content card">
                <view class="attr-time"><text>{{attr.displayTime}}</text></view>
                <view class="attr-name">{{attr.attractionName}}</view>
                <view class="attr-duration"><text>⏱️ {{attr.durationMinutes}}分钟</text></view>
                <view class="attr-notes" wx:if="{{attr.notes}}">
                  <text>{{attr.notes}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="day-notes" wx:if="{{day.notes}}">
            <text class="notes-label">📝 当日备注</text>
            <text class="notes-text">{{day.notes}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="edit-btn" bindtap="editItinerary">调整行程</button>
      <button class="confirm-btn btn-primary" bindtap="confirmItinerary">确认行程</button>
    </view>
  </view>

  <view class="card" wx:else>
    <text>行程加载中...</text>
  </view>
</view>
