<view class="container">
  <view class="welcome-section">
    <view class="welcome-card card">
      <view class="welcome-header">
        <text class="welcome-title">Hello, {{userInfo ? userInfo.nickName : 'Traveler'}}</text>
        <text class="welcome-subtitle">Start with one destination.</text>
      </view>
      <view class="welcome-image flex-center">
        <text>START</text>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="section-title">
      <text class="title-text">Quick Actions</text>
    </view>
    <view class="action-grid card">
      <view class="action-item" bindtap="goToPlan">
        <view class="action-icon plan-icon">
          <text>PLAN</text>
        </view>
        <text class="action-text">Create Plan</text>
      </view>
      <view class="action-item" bindtap="goToMyItineraries">
        <view class="action-icon itinerary-icon">
          <text>LIST</text>
        </view>
        <text class="action-text">My Trips</text>
      </view>
      <view class="action-item" bindtap="showComingSoon">
        <view class="action-icon chat-icon">
          <text>ASK</text>
        </view>
        <text class="action-text">Ask AI</text>
      </view>
      <view class="action-item" bindtap="showComingSoon">
        <view class="action-icon guide-icon">
          <text>GUIDE</text>
        </view>
        <text class="action-text">Guides</text>
      </view>
    </view>
  </view>

  <view class="destinations card">
    <view class="section-title">
      <text class="title-text">Popular Destinations</text>
    </view>
    <scroll-view class="destination-list" scroll-x="true">
      <view
        wx:for="{{destinations}}"
        wx:key="id"
        class="destination-item"
        bindtap="selectDestination"
        data-dest="{{item.name}}"
      >
        <view class="dest-image flex-center">
          <text>{{item.name}}</text>
        </view>
        <view class="dest-info">
          <text class="dest-name">{{item.name}}</text>
          <text class="dest-desc">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
