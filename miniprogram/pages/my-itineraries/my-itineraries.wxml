<!-- pages/my-itineraries/my-itineraries.wxml -->
<view class="container">
  <!-- 顶部 -->
  <view class="header">
    <view class="user-info" wx:if="{{userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '旅行者'}}</text>
        <text class="user-desc">开启智能旅行</text>
      </view>
    </view>
    <view class="user-info" wx:else bindtap="goToLogin">
      <view class="avatar placeholder">
        <text>👤</text>
      </view>
      <view class="user-detail">
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后查看您的行程</text>
      </view>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-section" wx:if="{{userInfo}}">
    <view class="stat-item">
      <text class="stat-number">{{stats.total}}</text>
      <text class="stat-label">总行程</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.planned}}</text>
      <text class="stat-label">规划中</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 行程列表 -->
  <view class="list-section" wx:if="{{userInfo}}">
    <view class="section-header">
      <text class="section-title">我的行程</text>
      <text class="section-action" bindtap="goToPlan">+ 新建行程</text>
    </view>

    <view class="itinerary-list" wx:if="{{itineraries.length > 0}}">
      <view class="itinerary-item card" wx:for="{{itineraries}}" wx:key="itineraryId" bindtap="viewItinerary" data-id="{{item.itineraryId}}">
        <view class="item-header">
          <text class="item-title">{{item.title}}</text>
          <view class="item-status {{item.status}}">
            <text>{{statusText(item.status)}}</text>
          </view>
        </view>
        <view class="item-info">
          <text class="info-item">📍 {{item.destination}}</text>
          <text class="info-item">🗓️ {{formatDateRange(item.startDate, item.endDate)}}</text>
          <text class="info-item">👥 {{item.travelerCount}}人</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">📋</text>
      <text class="empty-text">还没有行程</text>
      <text class="empty-desc">开始规划您的第一次旅行吧!</text>
      <button class="empty-btn btn-primary" bindtap="goToPlan">立即规划</button>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt" wx:if="{{!userInfo}}">
    <text class="prompt-icon">🔒</text>
    <text class="prompt-text">登录后查看您的行程</text>
    <button class="prompt-btn btn-primary" bindtap="goToLogin">立即登录</button>
  </view>
</view>
