<view class="container">
  <view class="header">
    <view class="user-info" wx:if="{{userInfo}}">
      <view class="avatar placeholder"><text>👤</text></view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-desc">这里负责查看已保存的行程。</text>
      </view>
    </view>
    <view class="user-info" wx:else bindtap="goToLogin">
      <view class="avatar placeholder"><text>🔐</text></view>
      <view class="user-detail">
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后查看和管理你的行程</text>
      </view>
    </view>
  </view>

  <view class="stats-section" wx:if="{{userInfo}}">
    <view class="stat-item">
      <text class="stat-number">{{stats.total}}</text>
      <text class="stat-label">总行程</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.planned}}</text>
      <text class="stat-label">已规划</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <view class="list-section" wx:if="{{userInfo}}">
    <view class="section-header">
      <text class="section-title">我的行程</text>
      <text class="section-action" bindtap="goToPlan">+ 新建行程</text>
    </view>

    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-text">正在加载行程...</text>
    </view>

    <view class="itinerary-list" wx:elif="{{itineraries.length > 0}}">
      <view class="itinerary-item card" wx:for="{{itineraries}}" wx:key="itineraryId" bindtap="viewItinerary" data-id="{{item.itineraryId}}">
        <view class="item-header">
          <text class="item-title">{{item.title}}</text>
          <view class="item-status {{item.status}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>
        <view class="item-info">
          <text class="info-item">📍 {{item.destination}}</text>
          <text class="info-item">🗓️ {{item.dateRangeText}}</text>
          <text class="info-item">👥 {{item.travelerCount}}人</text>
        </view>
        <text class="item-summary" wx:if="{{item.summaryText}}">{{item.summaryText}}</text>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">🧳</text>
      <text class="empty-text">还没有已保存的行程</text>
      <text class="empty-desc">先去填写需求，生成你的第一份方案。</text>
      <button class="empty-btn btn-primary" bindtap="goToPlan">开始规划</button>
    </view>
  </view>

  <view class="login-prompt" wx:if="{{!userInfo}}">
    <text class="prompt-icon">🔐</text>
    <text class="prompt-text">当前未登录，无法查看“我的行程”</text>
    <button class="prompt-btn btn-primary" bindtap="goToLogin">前往登录</button>
  </view>
</view>
