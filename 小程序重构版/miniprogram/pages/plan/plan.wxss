.label {
  display: block;
  margin: 16rpx 0 8rpx;
  font-weight: 600;
}

.input {
  height: 80rpx;
  margin-bottom: 8rpx;
  padding: 0 20rpx;
  line-height: 80rpx;
  border: 2rpx solid #dbe3ef;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.counter {
  display: flex;
  align-items: center;
  margin: 12rpx 0 24rpx;
}

.count {
  margin: 0 24rpx;
  min-width: 48rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 8rpx 0 20rpx;
}

.tag {
  padding: 12rpx 24rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334155;
}

.tag-active {
  border-color: #1989fa;
  background: #e8f3ff;
  color: #1989fa;
}

.submit-btn {
  margin-top: 8rpx;
}
