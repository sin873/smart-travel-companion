.map-card {
  margin-bottom: 20rpx;
}

.map-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.itinerary-map {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
}

.summary-card {
  margin-bottom: 20rpx;
}

.title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
}

.meta-line {
  display: block;
  margin-bottom: 10rpx;
  color: #475569;
}

.save-btn {
  margin-top: 20rpx;
}

.day-card {
  margin-bottom: 20rpx;
}

.day-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.day-date {
  display: block;
  margin-bottom: 8rpx;
  color: #1989fa;
}

.day-notes {
  display: block;
  margin-bottom: 16rpx;
  color: #64748b;
}

.spot-card {
  padding: 16rpx 0;
  border-top: 1rpx solid #e2e8f0;
}

.spot-line {
  display: block;
  margin-bottom: 8rpx;
  color: #334155;
  line-height: 1.6;
}

.spot-label {
  font-weight: 600;
  color: #0f172a;
}

.empty-box {
  padding-top: 8rpx;
}

.empty-text {
  color: #94a3b8;
}
